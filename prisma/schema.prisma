generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Activity {
  id             String   @id @default(cuid())
  date           DateTime
  activityType   String
  description    String
  amount         Float
  unit           String
  emissionFactor Float
  emission       Float
  scope          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([activityType])
  @@index([date])
  @@index([scope])
}

model EmissionFactor {
  id           String                  @id @default(cuid())
  key          String                  @unique
  name         String
  unit         String
  activityType String                  @default("electricity")
  createdAt    DateTime                @default(now())
  versions     EmissionFactorVersion[]

  @@index([activityType])
}

model EmissionFactorVersion {
  id               String         @id @default(cuid())
  emissionFactorId String
  factor           Float
  source           String
  validFrom        DateTime
  validTo          DateTime?
  createdAt        DateTime       @default(now())
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id], onDelete: Cascade)

  @@index([emissionFactorId])
  @@index([validFrom])
}

model ActivityType {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  unit      String
  scope     String
  createdAt DateTime @default(now())
}
